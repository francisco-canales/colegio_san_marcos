generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Alumno {
  id       Int     @id @default(autoincrement())
  nombre   String
  apellido String
  grado    String
  seccion  String

  @@map("alumnos")
}

enum Rol {
  ADMIN
  COORDINADOR
}

model Usuario {
  id           Int    @id @default(autoincrement())
  nombre       String
  email        String @unique
  passwordHash String
  rol          Rol    @default(COORDINADOR)
  activo       Boolean @default(true)

  @@map("usuarios")
}
